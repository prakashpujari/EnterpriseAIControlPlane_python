# Enterprise AI Customer Support Assistant - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME=Enterprise AI Customer Support Assistant
APP_VERSION=1.0.0
ENVIRONMENT=development

# =============================================================================
# DATABASE SETTINGS
# =============================================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# =============================================================================
# REDIS SETTINGS
# =============================================================================
REDIS_URL=redis://red-d836e2t7vvec73938sl0:6379
REDIS_RATE_LIMIT_TTL=3600

# =============================================================================
# PINECONE SETTINGS
# =============================================================================
PINECONE_API_KEY=pcsk_6Vtb2n_Hz4fzzdc9DSFvaKdGBrEwERN2f4Z1PAmmKMVVRfFcpsus7qdfpo8x9du9TcZmvm
PINECONE_ENVIRONMENT=us-west-2
PINECONE_RAG_INDEX=mortgageindex
PINECONE_LTM_INDEX=mortgageindex

# Pinecone Host (for direct connection)
PINECONE_HOST=https://mortgageindex-96hwyzx.svc.aped-4627-b74a.pinecone.io

# Mortgage API Key
MORTGAGE_API_KEY=pcsk_9VCYW_DKtQ8wWHPRKHfa1FTRgWn5nFQ9Wx8tBYaTLdnZLLRGdNrGoU1iUydxULVFP5d8j

# =============================================================================
# GROQ API SETTINGS
# =============================================================================
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com

# =============================================================================
# MODEL CONFIGURATION (Groq Models)
# =============================================================================
# Small: Fast, cheap for FAQ/compression
SMALL_MODEL=llama-3.1-8b-instant
# Medium: Good balance for RAG/summarize
MEDIUM_MODEL=llama-3.1-70b-versatile
# Large: Complex reasoning
LARGE_MODEL=mixtral-8x7b-32768

# =============================================================================
# TOKEN LIMITS PER ROLE
# =============================================================================
SUPPORT_ENGINEER_TOKEN_LIMIT=8000
MORTGAGE_ANALYST_TOKEN_LIMIT=10000
COMPLIANCE_OFFICER_TOKEN_LIMIT=12000
PRODUCT_OWNER_TOKEN_LIMIT=8000

# =============================================================================
# RATE LIMITING
# =============================================================================
REQUESTS_PER_MINUTE_PER_USER=60
REQUESTS_PER_HOUR_PER_USER=500

# =============================================================================
# RAG CONFIGURATION
# =============================================================================
RAG_TOP_K=20
RAG_FINAL_K=5
RAG_RE_RANKER_THRESHOLD=0.7

# =============================================================================
# MEMORY CONFIGURATION
# =============================================================================
STM_MAX_TURNS=5
STM_SUMMARY_THRESHOLD=10

# =============================================================================
# DRIFT DETECTION THRESHOLDS
# =============================================================================
QUALITY_THRESHOLD=0.7
COST_SPIKE_THRESHOLD=1.5
LATENCY_THRESHOLD_MS=5000

# =============================================================================
# PII SCANNING
# =============================================================================
PII_ENABLED=true
PII_CONFIDENCE_THRESHOLD=0.8

# =============================================================================
# LANGSMITH (OPTIONAL)
# =============================================================================
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=enterprise-ai-customer-support

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# =============================================================================
# SECURITY
# =============================================================================
JWT_SECRET_KEY=your_strong_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS=http://localhost:3000,https://localhost:3000