# Test Environment Configuration
APP_NAME=Enterprise AI Customer Support Assistant
APP_VERSION=1.0.0
ENVIRONMENT=development

# SQLite for testing (no PostgreSQL required)
DATABASE_URL=sqlite:///./test.db

REDIS_URL=redis://localhost:6379/0
REDIS_RATE_LIMIT_TTL=3600

# Pinecone - will use mock for testing
PINECONE_API_KEY=mock_pinecone_key
PINECONE_ENVIRONMENT=us-west-2
PINECONE_RAG_INDEX=mock-rag-index
PINECONE_LTM_INDEX=mock-ltm-index

GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com

SMALL_MODEL=llama-3.1-8b-instant
MEDIUM_MODEL=llama-3.3-70b-versatile
LARGE_MODEL=llama-3.3-70b-versatile

SUPPORT_ENGINEER_TOKEN_LIMIT=8000
MORTGAGE_ANALYST_TOKEN_LIMIT=10000
COMPLIANCE_OFFICER_TOKEN_LIMIT=12000
PRODUCT_OWNER_TOKEN_LIMIT=8000

REQUESTS_PER_MINUTE_PER_USER=60
REQUESTS_PER_HOUR_PER_USER=500

RAG_TOP_K=20
RAG_FINAL_K=5
RAG_RE_RANKER_THRESHOLD=0.7

STM_MAX_TURNS=5
STM_SUMMARY_THRESHOLD=10

QUALITY_THRESHOLD=0.7
COST_SPIKE_THRESHOLD=1.5
LATENCY_THRESHOLD_MS=5000

PII_ENABLED=true
PII_CONFIDENCE_THRESHOLD=0.8

LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=enterprise-ai-customer-support

LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name) - %(levelname)s - %(message)s

JWT_SECRET_KEY=test_jwt_secret_key_for_testing_only
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]